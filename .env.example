# LinkMágico Demo — Configuração

# ===== PROVEDORES DE IA (fallback: Groq → OpenRouter → OpenAI) =====
GROQ_API_KEY=INSIRA_SUA_CHAVE_GROQ_AQUI
OPENROUTER_API_KEY=INSIRA_SUA_CHAVE_OPENROUTER_AQUI
OPENAI_API_KEY=INSIRA_SUA_CHAVE_OPENAI_AQUI

# Modelos (opcional — defaults seguros)
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENAI_MODEL=gpt-4o-mini

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=production

# ===== LINK DE VENDA =====
HOTMART_LINK=https://pay.hotmart.com/G103177435I

# ===== LIMITES DEMO =====
DEMO_MAX_MESSAGES=20
DEMO_EXPIRY_MINUTES=30
DEMO_MAX_LINKS_PER_IP=1
